# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is in .gitignore.
#
# Set all of these as Environment Variables in your Vercel project settings.

# ---- Stripe ----
# Use test keys (sk_test_…) during development.
# Swap to live keys (sk_live_…) before launch.
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PRICE_ID=price_REPLACE_ME

# ---- Email (Resend) ----
# Sign up free at resend.com, verify solarsnap.co.uk, then create an API key.
RESEND_API_KEY=re_REPLACE_ME

# ---- Site URL ----
# Used to build Stripe success/cancel redirect URLs.
NEXT_PUBLIC_SITE_URL=https://solarsnap.co.uk
